{
  "name": "flisym",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "FLISYM — browser-based flight simulator (TypeScript + Three.js)",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:offline": "npm run build && node scripts/bundle-offline.mjs",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test --reporter=line",
    "server": "tsx server/index.ts"
  },
  "dependencies": {
    "cannon-es": "^0.20.0",
    "simplex-noise": "^4.0.3",
    "three": "^0.169.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/three": "^0.169.0",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.2",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "vitest": "^2.1.2",
    "ws": "^8.18.0"
  }
}
